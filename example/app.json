{
  "configVersion": "v3",
  "app": {
    "appId": 20001,
    "appName": "Zepp-Style-List",
    "appType": "app",
    "version": { "code": 1, "name": "1.0.0" },
    "icon": "icon.png",
    "vender": "ZHAO",
    "description": "Zepp-Style-List: ZeppOS system-style list example (Balance 480 round)"
  },
  "permissions": ["data:os.device.info"],
  "runtime": {
    "apiVersion": { "compatible": "3.0.0", "target": "3.0.0", "minVersion": "3.0" }
  },
  "targets": {
    "default": {
      "module": {
        "page": {
          "pages": [
            "page/index",
            "page/single",
            "page/multiline",
            "page/wrap",
            "page/square",
            "page/level1",
            "page/level2",
            "page/level3"
          ]
        }
      },
      "platforms": [{ "st": "r", "dw": 480 }, { "st": "s", "dw": 390 }],
      "designWidth": 480
    }
  },
  "i18n": {
    "en-US": { "appName": "Zepp-Style-List" },
    "zh-CN": { "appName": "Zepp-Style-List" }
  },
  "defaultLanguage": "zh-CN"
}
